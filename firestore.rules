rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn(); } // Any logged-in user is an admin for this demo
    
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Helpers
    function isValidSiteConfig(data) {
      return data.keys().hasAll(['schoolName', 'heroTitle', 'heroSubtitle', 'aboutTitle', 'aboutDescription', 'contactAddress', 'contactPhone', 'contactEmail', 'ppdbTitle', 'ppdbDescription', 'ppdbBrochureUrl', 'copyrightText'])
        && (data.keys().size() == 11 || data.keys().size() == 12)
        && data.schoolName is string && data.schoolName.size() <= 100
        && data.heroTitle is string && data.heroTitle.size() <= 200
        && data.heroSubtitle is string && data.heroSubtitle.size() <= 200
        && data.aboutTitle is string && data.aboutTitle.size() <= 200
        && data.aboutDescription is string && data.aboutDescription.size() <= 1000
        && data.contactAddress is string && data.contactAddress.size() <= 200
        && data.contactPhone is string && data.contactPhone.size() <= 50
        && data.contactEmail is string && data.contactEmail.size() <= 100
        && data.ppdbTitle is string && data.ppdbTitle.size() <= 200
        && data.ppdbDescription is string && data.ppdbDescription.size() <= 1000
        && data.ppdbBrochureUrl is string && data.ppdbBrochureUrl.size() <= 500
        && data.copyrightText is string && data.copyrightText.size() <= 200;
    }

    function isValidInformationItem(data) {
      return data.keys().hasAll(['title', 'content', 'date'])
        && data.keys().size() == 3
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 2000
        && data.date is string && data.date.size() <= 50;
    }

    function isValidRegistration(data) {
      return data.keys().hasAll(['name', 'address', 'birthDate', 'parentName', 'parentPhone', 'reportCardFile', 'familyCardFile', 'birthCertificateFile', 'submittedAt'])
        && data.keys().size() == 9
        && data.name is string && data.name.size() <= 150
        && data.address is string && data.address.size() <= 500
        && data.birthDate is string && data.birthDate.size() <= 50
        && data.parentName is string && data.parentName.size() <= 150
        && data.parentPhone is string && data.parentPhone.size() <= 50
        && data.reportCardFile is string && data.reportCardFile.size() <= 500
        && data.familyCardFile is string && data.familyCardFile.size() <= 500
        && data.birthCertificateFile is string && data.birthCertificateFile.size() <= 500
        && data.submittedAt is string && data.submittedAt.size() <= 50;
    }

    match /site/{configId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSiteConfig(incoming());
    }

    match /informationItems/{itemId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidInformationItem(incoming());
      allow delete: if isAdmin();
    }

    match /registrations/{regId} {
      allow create: if isValidRegistration(incoming()); // Public form
      allow read, list, update, delete: if isAdmin();
    }
  }
}
